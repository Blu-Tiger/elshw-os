#!/bin/sh
mount -t proc none /proc
mount -t sysfs none /sys
mkdir -p /run
mount -t tmpfs tmpfs /run
mount -t devtmpfs devtmpfs /dev
mdev -s 2>/dev/null || true
echo "add" > /sys/class/block/trigger 2>/dev/null || true

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

exec 0</dev/console
exec 1>/dev/console
exec 2>/dev/console

acpid

for iface in /sys/class/net/*; do
    iface=$(basename "$iface")
    [[ "$iface" == "lo" ]] && continue
    [[ ! -e "/sys/class/net/$iface/device" ]] && continue
    ip link set "$iface" up
    udhcpc -i "$iface" -n -q 2>/dev/null &
done
wait

echo "Boot complete. Gathering hardware info..."
sleep 2
dmesg -n 1
clear

while true; do
    /bin/bash /elshw.sh
    echo -e ""
    echo -e "\033[1;36m════════════════════════════════════════════════════════════\033[0m"
    echo -e ""
    echo -e "  \033[1mWhat do you want to do?\033[0m"
    echo -e "  \033[1;31m[S]\033[0m  Shutdown"
    echo -e "  \033[1;33m[R]\033[0m  Reboot  \033[2m(remove USB within 5 seconds)\033[0m"
    echo -e "  \033[1;32m[B]\033[0m  Drop to Bash shell"
    echo -e ""
    echo -ne "  \033[1mPress S, R, or B:\033[0m  "

    stty -echo -icanon min 1 time 0 < /dev/console

    while true; do
        key=$(dd if=/dev/console bs=1 count=1 2>/dev/null | od -An -tx1 | tr -d ' \n')
        case "$key" in
            73|53)  # 's' or 'S'  (hex 73 = s, 53 = S)
                stty echo icanon < /dev/console
                echo -e "\r\n"
                echo -e "  \033[1;31m▶ Shutting down...\033[0m"
                sleep 1
                poweroff -f
                sleep 10
                ;;
            72|52)  # 'r' or 'R'  (hex 72 = r, 52 = R)
                stty echo icanon < /dev/console
                echo -e "\r\n"
                echo -e "  \033[1;33m▶ Rebooting in 5 seconds — remove the USB now...\033[0m"
                for i in 5 4 3 2 1; do
                    echo -ne "  \033[1;33m${i}...\033[0m "
                    sleep 1
                done
                echo -e "\r\n"
                reboot -f
                sleep 10
                ;;
            62|42)  # 'b' or 'B'  (hex 62 = b, 42 = B)
                stty echo icanon < /dev/console
                echo -e "\r\n"
                echo -e "  \033[1;32m▶ Dropping to root shell. Type 'exit' to return to menu.\033[0m"
                echo -e ""

                setsid cttyhack /bin/bash

                break
                ;;
        esac
    done
done
